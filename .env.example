# ============================================================
# Required environment variables for stripe-rent-link
# ============================================================
# Copy this file to .env.local for local development.
# In production, set these in Vercel → Project Settings → Environment Variables.
# NEVER commit a file containing real keys — .gitignore already excludes .env*

# Your Stripe secret key.
# Use sk_test_... while testing, sk_live_... when going live.
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# (Optional) Page shown after a successful payment.
# Defaults to stripe.com — replace with your own thank-you page if you have one.
SUCCESS_URL=https://stripe.com

# (Optional) Page shown if the tenant clicks "Back" / cancels before paying.
# Defaults to stripe.com — replace with your own page if needed.
CANCEL_URL=https://stripe.com
